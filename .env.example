# .env.example — copy this file to .env and fill in real values for local development.
# Never commit your actual .env file — it's already excluded in .gitignore.
#
# In production (Render), do NOT use a .env file at all — set these same
# variable names directly in the Render dashboard under Environment.

# ── Required ──────────────────────────────────────────────────────────────

# Your Google Gemini API key. Get a free one (no credit card required) at:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here


# Flask session signing key. Generate a real one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# ── Optional (sensible defaults are used if omitted) ────────────────────────

# Which Gemini model to use. gemini-2.5-flash is the recommended default —
# stable and free-tier eligible. gemini-2.5-flash-lite is a lighter/faster
# option if you need higher requests-per-minute headroom.
GEMINI_MODEL=gemini-2.5-flash

# Where the SQLite database file lives. Leave as-is for local dev.
# On Render, point this at a mounted disk path (e.g. /var/data/study_assistant.db)
# if you want data to survive redeploys — see render.yaml.
DATABASE_PATH=study_assistant.db

# Port the Flask/Gunicorn server listens on. Render injects this automatically
# in production — you generally don't need to set it yourself.
PORT=5000

# Set to "true" to enable Flask's debug mode and auto-reload locally.
# Must be "false" (or omitted) in production.
FLASK_DEBUG=false

# Set to "true" once deployed behind HTTPS (Render gives you this by default)
# so session cookies are only sent over secure connections.
SESSION_COOKIE_SECURE=false

# Logging verbosity: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
