# .gitignore — AI Study Assistant

# Environment variables / secrets — never commit real API keys
.env
.env.local
.env.*.local

# SQLite database files (local dev data — not source)
*.db
*.db-journal
*.db-wal
*.db-shm
study_assistant.db

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.egg
.installed.cfg

# Virtual environments
venv/
env/
.venv/
ENV/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
*.log

# Render / deployment artifacts
.render/
